---
/**
 * Navbar Component - Premium Minimal Design
 * Clean, elegant, floating navbar with glassmorphism
 */

interface Props {
    locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

const t = {
    es: {
        shop: "Tienda",
        men: "Hombre",
        women: "Mujer",
        new: "Nuevo",
        search: "Buscar...",
    },
    en: {
        shop: "Shop",
        men: "Men",
        women: "Women",
        new: "New",
        search: "Search...",
    },
};

const text = t[locale];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 pt-4 px-4">
    <nav class="navbar-container">
        <div class="container-custom flex items-center justify-between py-3">
            <!-- Logo -->
            <a href="/" class="flex items-center group">
                <img
                    id="logo-light"
                    src="/LogoModoClaro.png"
                    alt="KØDE"
                    class="h-8 w-auto transition-transform duration-300 group-hover:scale-105 dark:hidden"
                />
                <img
                    id="logo-dark"
                    src="/LogoModoOscuro.png"
                    alt="KØDE"
                    class="h-8 w-auto transition-transform duration-300 group-hover:scale-105 hidden dark:block"
                />
            </a>

            <!-- Desktop Navigation - Center -->
            <div class="hidden md:flex items-center gap-10">
                <a href="/tienda" class="nav-link">{text.shop}</a>
                <a href="/hombre" class="nav-link">{text.men}</a>
                <a href="/mujer" class="nav-link">{text.women}</a>
                <a href="/nuevo" class="nav-link group">
                    {text.new}
                    <span class="new-badge">NEW</span>
                </a>
            </div>

            <!-- Right Actions -->
            <div class="flex items-center gap-2">
                <!-- Search -->
                <button
                    id="search-toggle"
                    class="nav-icon-btn"
                    aria-label="Buscar"
                >
                    <svg
                        class="w-[18px] h-[18px]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
                        ></path>
                    </svg>
                </button>

                <!-- Theme Toggle -->
                <button
                    id="theme-toggle"
                    class="nav-icon-btn"
                    aria-label="Cambiar tema"
                >
                    <svg
                        id="sun-icon"
                        class="w-[18px] h-[18px] hidden dark:block"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                        ></path>
                    </svg>
                    <svg
                        id="moon-icon"
                        class="w-[18px] h-[18px] block dark:hidden"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
                        ></path>
                    </svg>
                </button>

                <!-- User -->
                <a href="/cuenta" class="nav-icon-btn" aria-label="Mi cuenta">
                    <svg
                        class="w-[18px] h-[18px]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
                        ></path>
                    </svg>
                </a>

                <!-- Cart -->
                <a
                    href="/carrito"
                    class="nav-icon-btn relative"
                    aria-label="Carrito"
                >
                    <svg
                        class="w-[18px] h-[18px]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
                        ></path>
                    </svg>
                    <span id="cart-count" class="cart-badge hidden">0</span>
                </a>

                <!-- Mobile Menu Toggle -->
                <button
                    id="mobile-menu-toggle"
                    class="nav-icon-btn md:hidden ml-1"
                    aria-label="Menú"
                >
                    <svg
                        id="menu-icon"
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                    >
                        <path
                            id="menu-icon-open"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
                        <path
                            id="menu-icon-close"
                            class="hidden"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="md:hidden hidden overflow-hidden">
            <div
                class="py-4 px-2 flex flex-col gap-1 border-t border-[var(--border-color)]/50"
            >
                <a href="/tienda" class="mobile-nav-link">{text.shop}</a>
                <a href="/hombre" class="mobile-nav-link">{text.men}</a>
                <a href="/mujer" class="mobile-nav-link">{text.women}</a>
                <a href="/nuevo" class="mobile-nav-link">
                    {text.new}
                    <span class="new-badge ml-2">NEW</span>
                </a>
            </div>
        </div>
    </nav>
</header>

<!-- Spacer for fixed navbar -->
<div class="h-20"></div>

<style>
    .navbar-container {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    :global(.dark) .navbar-container {
        background: rgba(10, 10, 10, 0.75);
        border: 1px solid rgba(255, 255, 255, 0.06);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
    }

    .navbar-container:hover {
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.06);
    }

    :global(.dark) .navbar-container:hover {
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
    }

    .nav-link {
        position: relative;
        color: var(--text-secondary);
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        transition: color 0.2s ease;
    }

    .nav-link:hover {
        color: var(--text-primary);
    }

    .nav-link::after {
        content: "";
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--text-primary);
        transition: width 0.3s ease;
    }

    .nav-link:hover::after {
        width: 100%;
    }

    .new-badge {
        display: inline-flex;
        align-items: center;
        margin-left: 6px;
        padding: 2px 6px;
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.05em;
        background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
        color: white;
        border-radius: 4px;
        transform: translateY(-1px);
    }

    .nav-icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        color: var(--text-secondary);
        border-radius: 10px;
        transition: all 0.2s ease;
    }

    .nav-icon-btn:hover {
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    .cart-badge {
        position: absolute;
        top: 4px;
        right: 4px;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        font-size: 10px;
        font-weight: 600;
        line-height: 16px;
        text-align: center;
        background: var(--text-primary);
        color: var(--bg-primary);
        border-radius: 8px;
    }

    .mobile-nav-link {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        color: var(--text-secondary);
        font-size: 0.9375rem;
        font-weight: 500;
        border-radius: 10px;
        transition: all 0.2s ease;
    }

    .mobile-nav-link:hover {
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    /* Scroll effect */
    #navbar.scrolled .navbar-container {
        border-radius: 0;
        margin: 0 -16px;
        padding: 0 16px;
    }

    #navbar.scrolled {
        padding-top: 0;
        padding-left: 0;
        padding-right: 0;
    }
</style>

<script>
    import { toggleTheme } from "../lib/theme";

    // Theme toggle
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
        toggleTheme();
    });

    // Mobile menu toggle
    document
        .getElementById("mobile-menu-toggle")
        ?.addEventListener("click", () => {
            const menu = document.getElementById("mobile-menu");
            const iconOpen = document.getElementById("menu-icon-open");
            const iconClose = document.getElementById("menu-icon-close");

            menu?.classList.toggle("hidden");
            iconOpen?.classList.toggle("hidden");
            iconClose?.classList.toggle("hidden");
        });

    // Navbar scroll effect
    let lastScroll = 0;
    window.addEventListener("scroll", () => {
        const navbar = document.getElementById("navbar");
        const currentScroll = window.scrollY;

        if (currentScroll > 50) {
            navbar?.classList.add("scrolled");
        } else {
            navbar?.classList.remove("scrolled");
        }

        lastScroll = currentScroll;
    });
</script>
