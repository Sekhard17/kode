---
/**
 * Navbar Component - Professional Minimal Design
 * Clean, elegant navbar optimized for both desktop and mobile
 * SSR: Fetches user session from backend using cookies
 */

import AuthModal from "./auth/AuthModal.astro";
import UserDropdown from "./auth/UserDropdown.astro";
import type { UserDto } from "../types";

interface Props {
    locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

// SSR: Get current user from backend using cookies
let currentUser: UserDto | null = null;

try {
    const cookieHeader = Astro.request.headers.get("cookie") || "";
    const response = await fetch("http://localhost:5133/api/auth/me", {
        headers: {
            Cookie: cookieHeader,
        },
        credentials: "include",
    });

    if (response.ok) {
        currentUser = await response.json();
    }
} catch (error) {
    // User not authenticated or error fetching
    currentUser = null;
}

const isLoggedIn = currentUser !== null;

const t = {
    es: {
        shop: "Tienda",
        men: "Hombre",
        women: "Mujer",
        new: "Nuevo",
        search: "Buscar",
        theme: "Tema",
        wishlist: "Favoritos",
        cart: "Carrito",
        login: "Ingresar",
        account: "Mi cuenta",
        logout: "Cerrar sesión",
    },
    en: {
        shop: "Shop",
        men: "Men",
        women: "Women",
        new: "New",
        search: "Search",
        theme: "Theme",
        wishlist: "Wishlist",
        cart: "Cart",
        login: "Sign In",
        account: "Account",
        logout: "Sign out",
    },
};

const text = t[locale];
---

<header class="navbar">
    <div class="navbar__inner">
        <!-- Logo -->
        <a href="/" class="navbar__logo">
            <img src="/LogoModoClaro.png" alt="KØDE" class="logo-light" />
            <img src="/LogoModoOscuro.png" alt="KØDE" class="logo-dark" />
        </a>

        <!-- Desktop Navigation -->
        <nav class="navbar__nav">
            <a href="/tienda" class="navbar__link">{text.shop}</a>
            <a href="/hombre" class="navbar__link">{text.men}</a>
            <a href="/mujer" class="navbar__link">{text.women}</a>
            <a href="/nuevo" class="navbar__link">
                {text.new}
                <span class="badge-new">NEW</span>
            </a>
        </nav>

        <!-- Desktop Actions -->
        <div class="navbar__actions">
            <!-- Icon buttons with tooltips -->
            <button id="search-btn" class="icon-btn" data-tooltip={text.search}>
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
                    ></path>
                </svg>
            </button>

            <button id="theme-btn" class="icon-btn" data-tooltip={text.theme}>
                <svg
                    class="icon-sun"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                    ></path>
                </svg>
                <svg
                    class="icon-moon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
                    ></path>
                </svg>
            </button>

            <a href="/favoritos" class="icon-btn" data-tooltip={text.wishlist}>
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
                    ></path>
                </svg>
            </a>

            <a
                href="/carrito-compras"
                class="icon-btn"
                data-tooltip={text.cart}
            >
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
                    ></path>
                </svg>
                <span id="cart-badge" class="cart-badge">0</span>
            </a>

            <!-- User Section: Dropdown or Login Button -->
            {
                isLoggedIn && currentUser ? (
                    <UserDropdown user={currentUser} locale={locale} />
                ) : (
                    <button id="login-btn" class="btn-login">
                        {text.login}
                    </button>
                )
            }
        </div>

        <!-- Mobile: Menu Button -->
        <button id="menu-btn" class="menu-btn">
            <span class="menu-line"></span>
            <span class="menu-line"></span>
        </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="mobile-menu">
        <nav class="mobile-menu__nav">
            <a href="/tienda">{text.shop}</a>
            <a href="/hombre">{text.men}</a>
            <a href="/mujer">{text.women}</a>
            <a href="/nuevo">{text.new} <span class="badge-new">NEW</span></a>
        </nav>
        <div class="mobile-menu__divider"></div>
        <div class="mobile-menu__actions">
            <a href="/favoritos">{text.wishlist}</a>
            <a href="/cuenta">{text.account}</a>
        </div>

        {
            isLoggedIn && currentUser ? (
                <div class="mobile-menu__user">
                    <div class="mobile-user-info">
                        <div class="mobile-avatar">
                            <span>
                                {currentUser.firstName.charAt(0)}
                                {currentUser.lastName.charAt(0)}
                            </span>
                        </div>
                        <div class="mobile-user-details">
                            <span class="mobile-user-name">
                                {currentUser.firstName} {currentUser.lastName}
                            </span>
                            <span class="mobile-user-email">
                                {currentUser.email}
                            </span>
                        </div>
                    </div>
                    <button id="mobile-logout-btn" class="mobile-menu__logout">
                        {text.logout}
                    </button>
                </div>
            ) : (
                <button id="mobile-login-btn" class="mobile-menu__login">
                    {text.login}
                </button>
            )
        }
    </div>
</header>

<!-- Auth Modal -->
<AuthModal locale={locale} />

<style>
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }

    :global(.dark) .navbar {
        background: rgba(10, 10, 10, 0.92);
        border-bottom-color: rgba(255, 255, 255, 0.06);
    }

    .navbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 64px;
    }

    /* Logo */
    .navbar__logo {
        flex-shrink: 0;
    }

    .navbar__logo img {
        height: 28px;
        width: auto;
    }

    .logo-light {
        display: block;
    }
    .logo-dark {
        display: none;
    }
    :global(.dark) .logo-light {
        display: none;
    }
    :global(.dark) .logo-dark {
        display: block;
    }

    /* Desktop Nav */
    .navbar__nav {
        display: none;
        align-items: center;
        gap: 2rem;
    }

    @media (min-width: 1024px) {
        .navbar__nav {
            display: flex;
        }
    }

    .navbar__link {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
        transition: color 0.2s;
    }

    .navbar__link:hover {
        color: var(--text-primary);
    }

    .navbar__link::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -6px;
        width: 0;
        height: 1.5px;
        background: var(--text-primary);
        transition: width 0.25s ease;
    }

    .navbar__link:hover::after {
        width: 100%;
    }

    .badge-new {
        padding: 2px 6px;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: white;
        background: #ef4444;
        border-radius: 4px;
    }

    /* Desktop Actions */
    .navbar__actions {
        display: none;
        align-items: center;
        gap: 0.25rem;
    }

    @media (min-width: 1024px) {
        .navbar__actions {
            display: flex;
        }
    }

    /* Icon Button */
    .icon-btn {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        color: var(--text-secondary);
        border-radius: 10px;
        transition: all 0.2s;
    }

    .icon-btn svg {
        width: 20px;
        height: 20px;
    }

    .icon-btn:hover {
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    /* Tooltip */
    .icon-btn::before {
        content: attr(data-tooltip);
        position: absolute;
        top: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%);
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
        color: white;
        background: #1a1a1a;
        border-radius: 6px;
        opacity: 0;
        visibility: hidden;
        transition: all 0.2s;
        pointer-events: none;
    }

    .icon-btn:hover::before {
        opacity: 1;
        visibility: visible;
    }

    /* Theme icons */
    .icon-sun {
        display: none;
    }
    .icon-moon {
        display: block;
    }
    :global(.dark) .icon-sun {
        display: block;
    }
    :global(.dark) .icon-moon {
        display: none;
    }

    /* Cart badge */
    .cart-badge {
        position: absolute;
        top: 4px;
        right: 4px;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        font-size: 10px;
        font-weight: 700;
        line-height: 16px;
        text-align: center;
        color: white;
        background: #ef4444;
        border-radius: 8px;
        display: none;
    }

    .cart-badge.visible {
        display: block;
    }

    /* Login Button */
    .btn-login {
        margin-left: 0.75rem;
        padding: 0.5rem 1.25rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-inverse);
        background: var(--text-primary);
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-login:hover {
        opacity: 0.85;
    }

    /* Mobile Menu Button */
    .menu-btn {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        padding: 10px;
        background: none;
        border: none;
        cursor: pointer;
    }

    @media (min-width: 1024px) {
        .menu-btn {
            display: none;
        }
    }

    .menu-line {
        display: block;
        width: 20px;
        height: 1.5px;
        background: var(--text-primary);
        border-radius: 1px;
        transition: all 0.3s ease;
    }

    .menu-btn.active .menu-line:first-child {
        transform: rotate(45deg) translate(2px, 2px);
    }

    .menu-btn.active .menu-line:last-child {
        transform: rotate(-45deg) translate(2px, -2px);
    }

    /* Mobile Menu */
    .mobile-menu {
        display: none;
        position: fixed;
        top: 64px;
        left: 0;
        right: 0;
        bottom: 0;
        padding: 2rem 1.5rem;
        background: var(--bg-primary);
        overflow-y: auto;
        animation: fadeIn 0.2s ease;
    }

    @media (min-width: 1024px) {
        .mobile-menu {
            display: none !important;
        }
    }

    .mobile-menu.open {
        display: block;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .mobile-menu__nav {
        display: flex;
        flex-direction: column;
    }

    .mobile-menu__nav a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem 0;
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--text-primary);
        border-bottom: 1px solid var(--border-color);
    }

    .mobile-menu__divider {
        height: 1px;
        margin: 1.5rem 0;
        background: var(--border-color);
    }

    .mobile-menu__actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .mobile-menu__actions a {
        padding: 0.75rem 0;
        font-size: 1rem;
        color: var(--text-secondary);
    }

    .mobile-menu__login {
        display: block;
        width: 100%;
        margin-top: 2rem;
        padding: 1rem;
        font-size: 1rem;
        font-weight: 600;
        text-align: center;
        color: var(--text-inverse);
        background: var(--text-primary);
        border: none;
        border-radius: 10px;
        cursor: pointer;
    }

    /* Mobile User Section */
    .mobile-menu__user {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }

    .mobile-user-info {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.5rem 0;
    }

    .mobile-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
    }

    .mobile-avatar span {
        font-size: 1rem;
        font-weight: 600;
        color: white;
        text-transform: uppercase;
    }

    .mobile-user-details {
        display: flex;
        flex-direction: column;
    }

    .mobile-user-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .mobile-user-email {
        font-size: 0.875rem;
        color: var(--text-tertiary);
    }

    .mobile-menu__logout {
        display: block;
        width: 100%;
        margin-top: 1rem;
        padding: 0.875rem 1rem;
        font-size: 0.9375rem;
        font-weight: 500;
        text-align: center;
        color: #dc2626;
        background: rgba(220, 38, 38, 0.08);
        border: 1px solid rgba(220, 38, 38, 0.2);
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .mobile-menu__logout:hover {
        background: rgba(220, 38, 38, 0.12);
    }
</style>

<script>
    import { toggleTheme } from "../lib/theme";

    // Theme toggle
    document
        .getElementById("theme-btn")
        ?.addEventListener("click", toggleTheme);

    // Mobile menu
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    menuBtn?.addEventListener("click", () => {
        menuBtn.classList.toggle("active");
        mobileMenu?.classList.toggle("open");
        document.body.style.overflow = mobileMenu?.classList.contains("open")
            ? "hidden"
            : "";
    });

    // Close on link click
    mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            menuBtn?.classList.remove("active");
            mobileMenu?.classList.remove("open");
            document.body.style.overflow = "";
        });
    });

    // Cart badge
    function updateCartBadge() {
        const badge = document.getElementById("cart-badge");
        // TODO: Connect to cart state
        const count = 0;
        if (badge) {
            badge.textContent = String(count);
            badge.classList.toggle("visible", count > 0);
        }
    }

    updateCartBadge();

    // Login buttons - open auth modal
    const loginBtn = document.getElementById("login-btn");
    const mobileLoginBtn = document.getElementById("mobile-login-btn");

    function openAuthModal() {
        // Close mobile menu if open
        menuBtn?.classList.remove("active");
        mobileMenu?.classList.remove("open");
        document.body.style.overflow = "";

        // Open auth modal
        window.dispatchEvent(
            new CustomEvent("auth:open-modal", { detail: { mode: "login" } }),
        );
    }

    loginBtn?.addEventListener("click", openAuthModal);
    mobileLoginBtn?.addEventListener("click", openAuthModal);

    // Mobile logout button
    const mobileLogoutBtn = document.getElementById("mobile-logout-btn");

    mobileLogoutBtn?.addEventListener("click", async () => {
        try {
            // Call logout endpoint
            await fetch("http://localhost:5133/api/auth/logout", {
                method: "POST",
                credentials: "include",
            });
        } catch (error) {
            console.error("Logout error:", error);
        }
        // Reload page regardless
        window.location.reload();
    });
</script>
