---
/**
 * Navbar Component
 * Features: Logo (theme-aware), navigation, theme toggle, language, currency, cart, user
 */

interface Props {
    locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

// Traducciones para SSR
const t = {
    es: {
        home: "Inicio",
        shop: "Tienda",
        men: "Hombre",
        women: "Mujer",
        new: "Nuevo",
        search: "Buscar productos...",
    },
    en: {
        home: "Home",
        shop: "Shop",
        men: "Men",
        women: "Women",
        new: "New",
        search: "Search products...",
    },
};

const text = t[locale];
---

<header
    id="navbar"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
    <!-- Top bar -->
    <div class="bg-secondary border-b border-[var(--border-color)]">
        <div
            class="container-custom flex items-center justify-between py-2 text-xs"
        >
            <span class="text-tertiary"
                >Envío gratis en compras sobre $50.000</span
            >
            <div class="flex items-center gap-4">
                <!-- Language Selector -->
                <button
                    id="locale-toggle"
                    class="flex items-center gap-1 text-secondary hover:text-primary transition-colors"
                    aria-label="Cambiar idioma"
                >
                    <span id="current-locale" class="uppercase font-medium"
                        >{locale}</span
                    >
                    <svg
                        class="w-3 h-3"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>

                <!-- Currency Selector -->
                <button
                    id="currency-toggle"
                    class="flex items-center gap-1 text-secondary hover:text-primary transition-colors"
                    aria-label="Cambiar moneda"
                >
                    <span id="current-currency" class="font-medium">CLP</span>
                    <svg
                        class="w-3 h-3"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Main navbar -->
    <nav
        class="bg-primary/80 backdrop-blur-md border-b border-[var(--border-color)]"
    >
        <div class="container-custom flex items-center justify-between py-4">
            <!-- Logo -->
            <a href="/" class="flex items-center">
                <img
                    id="logo-light"
                    src="/Logo_KODE.jpeg"
                    alt="KØDE"
                    class="h-10 w-auto dark:hidden"
                />
                <img
                    id="logo-dark"
                    src="/LogoModoOscuro.png"
                    alt="KØDE"
                    class="h-10 w-auto hidden dark:block"
                />
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-8">
                <a href="/" class="nav-link">{text.home}</a>
                <a href="/tienda" class="nav-link">{text.shop}</a>
                <a href="/hombre" class="nav-link">{text.men}</a>
                <a href="/mujer" class="nav-link">{text.women}</a>
                <a href="/nuevo" class="nav-link relative">
                    {text.new}
                    <span
                        class="absolute -top-2 -right-4 badge badge-sale text-[10px]"
                        >NEW</span
                    >
                </a>
            </div>

            <!-- Right Actions -->
            <div class="flex items-center gap-4">
                <!-- Search -->
                <button
                    id="search-toggle"
                    class="p-2 text-secondary hover:text-primary transition-colors"
                    aria-label="Buscar"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                        ></path>
                    </svg>
                </button>

                <!-- Theme Toggle -->
                <button
                    id="theme-toggle"
                    class="p-2 text-secondary hover:text-primary transition-colors"
                    aria-label="Cambiar tema"
                >
                    <!-- Sun icon (shown in dark mode) -->
                    <svg
                        id="sun-icon"
                        class="w-5 h-5 hidden dark:block"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                        ></path>
                    </svg>
                    <!-- Moon icon (shown in light mode) -->
                    <svg
                        id="moon-icon"
                        class="w-5 h-5 block dark:hidden"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                        ></path>
                    </svg>
                </button>

                <!-- User -->
                <a
                    href="/cuenta"
                    class="p-2 text-secondary hover:text-primary transition-colors"
                    aria-label="Mi cuenta"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                </a>

                <!-- Cart -->
                <a
                    href="/carrito"
                    class="p-2 text-secondary hover:text-primary transition-colors relative"
                    aria-label="Carrito"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"
                        ></path>
                    </svg>
                    <span
                        id="cart-count"
                        class="absolute -top-1 -right-1 w-4 h-4 bg-[var(--accent-primary)] text-[var(--text-inverse)] text-xs rounded-full flex items-center justify-center hidden"
                        >0</span
                    >
                </a>

                <!-- Mobile Menu Toggle -->
                <button
                    id="mobile-menu-toggle"
                    class="p-2 md:hidden text-secondary hover:text-primary transition-colors"
                    aria-label="Menú"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            id="menu-icon-open"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                        <path
                            id="menu-icon-close"
                            class="hidden"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div
            id="mobile-menu"
            class="md:hidden hidden bg-primary border-t border-[var(--border-color)]"
        >
            <div class="container-custom py-4 flex flex-col gap-4">
                <a href="/" class="nav-link py-2">{text.home}</a>
                <a href="/tienda" class="nav-link py-2">{text.shop}</a>
                <a href="/hombre" class="nav-link py-2">{text.men}</a>
                <a href="/mujer" class="nav-link py-2">{text.women}</a>
                <a href="/nuevo" class="nav-link py-2">{text.new}</a>
            </div>
        </div>
    </nav>
</header>

<style>
    .nav-link {
        color: var(--text-secondary);
        font-weight: 500;
        font-size: 0.875rem;
        transition: color 0.2s ease;
    }

    .nav-link:hover {
        color: var(--text-primary);
    }

    .bg-primary {
        background-color: var(--bg-primary);
    }

    .bg-secondary {
        background-color: var(--bg-secondary);
    }
</style>

<script>
    import { toggleTheme } from "../lib/theme";
    import { toggleLocale, getLocale } from "../lib/i18n";
    import { toggleCurrency, getCurrency } from "../lib/currency";

    // Theme toggle
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
        toggleTheme();
    });

    // Locale toggle
    document.getElementById("locale-toggle")?.addEventListener("click", () => {
        const newLocale = toggleLocale();
        const el = document.getElementById("current-locale");
        if (el) el.textContent = newLocale.toUpperCase();
        // Reload to apply translations (in a real app, you'd use client-side routing)
        window.location.reload();
    });

    // Currency toggle
    document
        .getElementById("currency-toggle")
        ?.addEventListener("click", () => {
            const newCurrency = toggleCurrency();
            const el = document.getElementById("current-currency");
            if (el) el.textContent = newCurrency;
            // Dispatch event for other components to react
            window.dispatchEvent(
                new CustomEvent("currency-changed", { detail: newCurrency }),
            );
        });

    // Mobile menu toggle
    document
        .getElementById("mobile-menu-toggle")
        ?.addEventListener("click", () => {
            const menu = document.getElementById("mobile-menu");
            const iconOpen = document.getElementById("menu-icon-open");
            const iconClose = document.getElementById("menu-icon-close");

            menu?.classList.toggle("hidden");
            iconOpen?.classList.toggle("hidden");
            iconClose?.classList.toggle("hidden");
        });

    // Initialize values on load
    document.addEventListener("DOMContentLoaded", () => {
        const localeEl = document.getElementById("current-locale");
        const currencyEl = document.getElementById("current-currency");

        if (localeEl) localeEl.textContent = getLocale().toUpperCase();
        if (currencyEl) currencyEl.textContent = getCurrency();
    });

    // Navbar scroll effect
    let lastScroll = 0;
    window.addEventListener("scroll", () => {
        const navbar = document.getElementById("navbar");
        const currentScroll = window.scrollY;

        if (currentScroll > 100) {
            navbar?.classList.add("shadow-md");
        } else {
            navbar?.classList.remove("shadow-md");
        }

        lastScroll = currentScroll;
    });
</script>
