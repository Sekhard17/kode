---
/**
 * CartItem - Componente de item individual del carrito
 * @module components/carrito-compras/CartItem
 */
import type { CartItemDto } from "../../types";
import { SizeLabels, type Size } from "../../types";
import type { CartTranslations } from "../../lib/translations/cart";

interface Props {
    item: CartItemDto;
    text: CartTranslations;
    index: number;
}

const { item, text, index } = Astro.props;

function getSizeLabel(size: Size): string {
    return SizeLabels[size] || "N/A";
}
---

<article
    class="cart-item card p-4 flex flex-col sm:flex-row gap-4 animate-slide-up"
    style={`animation-delay: ${index * 100}ms`}
    data-item-id={item.id}
    data-unit-price={item.unitPrice}
>
    <!-- Imagen -->
    <a
        href={`/producto/${item.productSlug}`}
        class="flex-shrink-0 w-full sm:w-28 h-36 rounded-lg overflow-hidden group"
    >
        {
            item.productImageUrl ? (
                <img
                    src={item.productImageUrl}
                    alt={item.productName}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-full bg-[var(--bg-tertiary)] flex items-center justify-center">
                    <svg
                        class="w-12 h-12 text-tertiary"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1"
                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                        />
                    </svg>
                </div>
            )
        }
    </a>

    <!-- Información -->
    <div class="flex-1 flex flex-col justify-between">
        <div>
            <a
                href={`/producto/${item.productSlug}`}
                class="font-semibold text-lg hover:text-[var(--accent-primary)] transition-colors line-clamp-1"
            >
                {item.productName}
            </a>

            <div class="flex items-center gap-3 mt-1 text-sm text-secondary">
                <span class="px-2 py-0.5 bg-[var(--bg-tertiary)] rounded">
                    {text.size}: {getSizeLabel(item.size)}
                </span>
                <span class="unit-price" data-price={item.unitPrice}></span>
            </div>
        </div>

        <!-- Controles -->
        <div class="flex items-center justify-between mt-4">
            <div class="quantity-controls flex items-center gap-2">
                <button
                    class="quantity-btn decrease w-8 h-8 rounded-lg border border-[var(--border-color)] flex items-center justify-center hover:bg-[var(--bg-hover)] transition-all hover:scale-105"
                    data-item-id={item.id}
                    data-action="decrease"
                    type="button"
                    aria-label="Disminuir cantidad"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M20 12H4"></path>
                    </svg>
                </button>

                <span
                    class="quantity-display w-10 text-center font-medium transition-transform"
                    data-item-id={item.id}
                >
                    {item.quantity}
                </span>

                <button
                    class="quantity-btn increase w-8 h-8 rounded-lg border border-[var(--border-color)] flex items-center justify-center hover:bg-[var(--bg-hover)] transition-all hover:scale-105"
                    data-item-id={item.id}
                    data-action="increase"
                    type="button"
                    aria-label="Aumentar cantidad"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"></path>
                    </svg>
                </button>
            </div>

            <div class="flex items-center gap-4">
                <span
                    class="item-total font-bold text-lg"
                    data-item-id={item.id}
                    data-price={item.totalPrice}></span>

                <button
                    class="remove-btn p-2 text-[var(--text-tertiary)] hover:text-[var(--error)] transition-colors hover:scale-110"
                    data-item-id={item.id}
                    type="button"
                    aria-label={text.remove}
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                        ></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</article>

<style>
    .cart-item {
        transition: all 0.3s ease;
    }

    .cart-item.removing {
        opacity: 0;
        transform: translateX(-100px);
    }

    .cart-item:hover {
        box-shadow: var(--shadow-md);
    }

    .quantity-btn:active {
        transform: scale(0.95);
    }

    .text-tertiary {
        color: var(--text-tertiary);
    }

    .text-secondary {
        color: var(--text-secondary);
    }
</style>
