---
/**
 * OrderSummary - Resumen del pedido
 * @module components/carrito-compras/OrderSummary
 */
import type { CartTranslations } from "../../lib/translations/cart";

interface Props {
    subtotal: number;
    isFreeShipping: boolean;
    shippingProgress: number;
    text: CartTranslations;
}

const { subtotal, isFreeShipping, shippingProgress, text } = Astro.props;
---

<aside class="lg:col-span-1">
    <div
        class="order-summary card p-6 sticky top-28 animate-slide-up"
        style="animation-delay: 300ms"
    >
        <h2 class="text-xl font-bold mb-6">
            {text.orderSummary}
        </h2>

        <div class="space-y-4 text-sm">
            <div class="flex justify-between">
                <span class="text-secondary">{text.subtotal}</span>
                <span
                    id="subtotal-display"
                    class="font-medium"
                    data-price={subtotal}></span>
            </div>

            <div class="flex justify-between">
                <span class="text-secondary">{text.shipping}</span>
                <span
                    class={`font-medium ${isFreeShipping ? "text-[var(--success)]" : ""}`}
                >
                    {
                        isFreeShipping
                            ? text.shippingFree
                            : text.shippingCalculated
                    }
                </span>
            </div>

            <div class="border-t border-[var(--border-color)] pt-4">
                <div class="flex justify-between items-center">
                    <span class="font-semibold text-lg">{text.orderTotal}</span>
                    <span
                        id="total-display"
                        class="font-bold text-xl"
                        data-price={subtotal}></span>
                </div>
            </div>
        </div>

        {
            !isFreeShipping && (
                <div class="mt-4 p-3 rounded-lg bg-[var(--bg-tertiary)] text-sm">
                    <p class="text-secondary">{text.freeShippingNote}</p>
                    <div class="mt-2 h-2 bg-[var(--border-color)] rounded-full overflow-hidden">
                        <div
                            class="h-full bg-gradient-to-r from-[var(--accent-primary)] to-[var(--success)] rounded-full transition-all duration-500"
                            id="shipping-progress"
                            style={`width: ${shippingProgress}%`}
                        />
                    </div>
                </div>
            )
        }

        <button
            class="checkout-btn w-full btn btn-primary mt-6 py-4 text-base font-semibold group"
            type="button"
        >
            <span>{text.checkout}</span>
            <svg
                class="w-5 h-5 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
        </button>

        <div
            class="flex items-center justify-center gap-2 mt-4 text-xs text-tertiary"
        >
            <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                ></path>
            </svg>
            <span>{text.secureCheckout}</span>
        </div>

        <div
            class="flex items-center justify-center gap-3 mt-4 pt-4 border-t border-[var(--border-color)]"
        >
            <div class="flex items-center gap-2 text-tertiary text-xs">
                <span
                    class="px-2 py-1 border border-[var(--border-color)] rounded"
                    >Visa</span
                >
                <span
                    class="px-2 py-1 border border-[var(--border-color)] rounded"
                    >MC</span
                >
                <span
                    class="px-2 py-1 border border-[var(--border-color)] rounded"
                    >PayPal</span
                >
            </div>
        </div>
    </div>
</aside>

<style>
    .order-summary {
        background: linear-gradient(
            135deg,
            var(--bg-card) 0%,
            var(--bg-secondary) 100%
        );
    }

    .checkout-btn {
        position: relative;
        overflow: hidden;
    }

    .checkout-btn::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.1),
            transparent
        );
        transition: left 0.5s ease;
    }

    .checkout-btn:hover::before {
        left: 100%;
    }

    .text-tertiary {
        color: var(--text-tertiary);
    }

    .text-secondary {
        color: var(--text-secondary);
    }
</style>
