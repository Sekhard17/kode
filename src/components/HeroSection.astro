---
/**
 * Hero Section Component
 * Main hero with animated text and CTA
 */

interface Props {
    locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

const t = {
    es: {
        title: "Nueva Colección",
        subtitle: "Descubre las últimas tendencias en moda urbana premium",
        cta: "Explorar Ahora",
        ctaSecondary: "Ver Catálogo",
    },
    en: {
        title: "New Collection",
        subtitle: "Discover the latest trends in premium urban fashion",
        cta: "Explore Now",
        ctaSecondary: "View Catalog",
    },
};

const text = t[locale];
---

<section
    class="relative min-h-[90vh] flex items-center justify-center overflow-hidden"
>
    <!-- Background gradient -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-[var(--bg-secondary)] via-[var(--bg-primary)] to-[var(--bg-tertiary)]"
    >
    </div>

    <!-- Animated background shapes -->
    <div class="absolute inset-0 overflow-hidden">
        <div class="hero-shape hero-shape-1"></div>
        <div class="hero-shape hero-shape-2"></div>
        <div class="hero-shape hero-shape-3"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 container-custom text-center">
        <div class="max-w-4xl mx-auto">
            <!-- Badge -->
            <div class="animate-slide-down mb-6">
                <span
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--bg-tertiary)] text-sm font-medium"
                >
                    <span
                        class="w-2 h-2 rounded-full bg-[var(--success)] animate-pulse"
                    ></span>
                    2024 Collection
                </span>
            </div>

            <!-- Title -->
            <h1
                class="hero-title text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-6"
            >
                <span
                    class="block animate-slide-up"
                    style="animation-delay: 100ms;">{text.title}</span
                >
            </h1>

            <!-- Subtitle -->
            <p
                class="text-lg sm:text-xl md:text-2xl text-secondary max-w-2xl mx-auto mb-10 animate-slide-up"
                style="animation-delay: 200ms;"
            >
                {text.subtitle}
            </p>

            <!-- CTAs -->
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up"
                style="animation-delay: 300ms;"
            >
                <a href="/tienda" class="btn btn-primary text-lg px-8 py-4">
                    {text.cta}
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
                <a
                    href="/categorias"
                    class="btn btn-secondary text-lg px-8 py-4"
                >
                    {text.ctaSecondary}
                </a>
            </div>

            <!-- Scroll indicator -->
            <div
                class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"
            >
                <svg
                    class="w-6 h-6 text-tertiary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-title {
        background: linear-gradient(
            135deg,
            var(--text-primary) 0%,
            var(--text-secondary) 50%,
            var(--text-primary) 100%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradient-shift 8s ease infinite;
    }

    @keyframes gradient-shift {
        0%,
        100% {
            background-position: 0% center;
        }
        50% {
            background-position: 100% center;
        }
    }

    .hero-shape {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.3;
    }

    .hero-shape-1 {
        width: 600px;
        height: 600px;
        background: var(--accent-primary);
        top: -200px;
        right: -200px;
        animation: float 20s ease-in-out infinite;
    }

    .hero-shape-2 {
        width: 400px;
        height: 400px;
        background: var(--text-tertiary);
        bottom: -100px;
        left: -100px;
        animation: float 25s ease-in-out infinite reverse;
    }

    .hero-shape-3 {
        width: 300px;
        height: 300px;
        background: var(--accent-secondary);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        animation: float 15s ease-in-out infinite;
    }

    @keyframes float {
        0%,
        100% {
            transform: translate(0, 0);
        }
        25% {
            transform: translate(30px, -30px);
        }
        50% {
            transform: translate(-20px, 20px);
        }
        75% {
            transform: translate(20px, 30px);
        }
    }

    .dark .hero-shape {
        opacity: 0.15;
    }
</style>
