---
/**
 * Hero Section - Glass Card Design
 * Content in glassmorphism card, bottom left
 */

interface Props {
    locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

const t = {
    es: {
        tagline: "Nueva Colección 2026",
        title: "Redefine tu estilo",
        subtitle:
            "Streetwear premium con diseños exclusivos que fusionan la esencia urbana con elegancia contemporánea.",
        cta: "Ver Colección",
    },
    en: {
        tagline: "New Collection 2026",
        title: "Redefine your style",
        subtitle:
            "Premium streetwear with exclusive designs that merge urban essence with contemporary elegance.",
        cta: "Shop Collection",
    },
};

const text = t[locale];

const slides = [
    { image: "/hero/Kode1.png", alt: "KØDE Collection" },
    { image: "/hero/Kode2.png", alt: "KØDE Collection" },
    { image: "/hero/Kode3.png", alt: "KØDE Collection" },
];
---

<section class="hero">
    <!-- Background Carousel -->
    <div class="hero-carousel">
        {
            slides.map((slide, index) => (
                <div
                    class={`hero-slide ${index === 0 ? "active" : ""}`}
                    data-slide={index}
                >
                    <img
                        src={slide.image}
                        alt={slide.alt}
                        class="hero-image"
                        loading={index === 0 ? "eager" : "lazy"}
                    />
                </div>
            ))
        }
    </div>

    <!-- Content -->
    <div class="hero-content">
        <!-- Glass Card -->
        <div class="hero-card">
            <span class="hero-tagline">{text.tagline}</span>
            <h1 class="hero-title">{text.title}</h1>
            <p class="hero-subtitle">{text.subtitle}</p>
            <a href="/tienda" class="hero-cta">
                <span>{text.cta}</span>
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"></path>
                </svg>
            </a>
        </div>
    </div>

    <!-- Indicators -->
    <div class="hero-indicators">
        {
            slides.map((_, index) => (
                <button
                    class={`indicator ${index === 0 ? "active" : ""}`}
                    data-indicator={index}
                    aria-label={`Slide ${index + 1}`}
                />
            ))
        }
    </div>
</section>

<style>
    .hero {
        position: relative;
        width: 100%;
        height: 100svh;
        min-height: 600px;
        overflow: hidden;
        background: #000;
    }

    /* Carousel */
    .hero-carousel {
        position: absolute;
        inset: 0;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    .hero-slide.active {
        opacity: 1;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    @media (max-width: 768px) {
        .hero-image {
            object-position: center 30%;
        }
    }

    /* Content */
    .hero-content {
        position: absolute;
        bottom: 4rem;
        left: 2rem;
        z-index: 10;
    }

    @media (min-width: 1024px) {
        .hero-content {
            left: 4rem;
            bottom: 5rem;
        }
    }

    @media (max-width: 768px) {
        .hero-content {
            left: 1rem;
            right: 1rem;
            bottom: 5rem;
        }
    }

    /* Glass Card */
    .hero-card {
        max-width: 440px;
        padding: 2rem;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        animation: cardSlideUp 0.8s ease forwards;
        animation-delay: 0.2s;
        opacity: 0;
    }

    @media (min-width: 768px) {
        .hero-card {
            padding: 2.5rem;
        }
    }

    @media (max-width: 768px) {
        .hero-card {
            max-width: 100%;
            border-radius: 16px;
        }
    }

    /* Tagline */
    .hero-tagline {
        display: inline-block;
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 1rem;
    }

    /* Title */
    .hero-title {
        font-size: clamp(1.75rem, 5vw, 2.5rem);
        font-weight: 700;
        line-height: 1.1;
        color: #fff;
        margin-bottom: 1rem;
    }

    /* Subtitle */
    .hero-subtitle {
        font-size: 0.9375rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 1.5rem;
    }

    @media (max-width: 768px) {
        .hero-subtitle {
            font-size: 0.875rem;
        }
    }

    /* CTA */
    .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: #000;
        background: #fff;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .hero-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
    }

    .hero-cta svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
    }

    .hero-cta:hover svg {
        transform: translateX(4px);
    }

    /* Indicators */
    .hero-indicators {
        position: absolute;
        bottom: 4rem;
        right: 2rem;
        display: flex;
        gap: 8px;
        z-index: 20;
    }

    @media (min-width: 1024px) {
        .hero-indicators {
            bottom: 5rem;
            right: 4rem;
        }
    }

    @media (max-width: 768px) {
        .hero-indicators {
            bottom: 1.5rem;
            right: auto;
            left: 50%;
            transform: translateX(-50%);
        }
    }

    .indicator {
        width: 32px;
        height: 3px;
        background: rgba(255, 255, 255, 0.3);
        border: none;
        border-radius: 2px;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .indicator::after {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 0;
        background: #fff;
        border-radius: 2px;
    }

    .indicator.active::after {
        animation: progress 5s linear forwards;
    }

    .indicator:hover {
        background: rgba(255, 255, 255, 0.5);
    }

    /* Animations */
    @keyframes cardSlideUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes progress {
        from {
            width: 0;
        }
        to {
            width: 100%;
        }
    }
</style>

<script>
    const slides = document.querySelectorAll(".hero-slide");
    const indicators = document.querySelectorAll(".indicator");
    let currentSlide = 0;
    let slideInterval: ReturnType<typeof setInterval>;

    function goToSlide(index: number) {
        slides.forEach((slide) => slide.classList.remove("active"));
        indicators.forEach((ind) => ind.classList.remove("active"));
        slides[index]?.classList.add("active");
        indicators[index]?.classList.add("active");
        currentSlide = index;
    }

    function nextSlide() {
        goToSlide((currentSlide + 1) % slides.length);
    }

    function startAutoRotate() {
        slideInterval = setInterval(nextSlide, 5000);
    }

    indicators.forEach((indicator, index) => {
        indicator.addEventListener("click", () => {
            goToSlide(index);
            clearInterval(slideInterval);
            startAutoRotate();
        });
    });

    startAutoRotate();

    const hero = document.querySelector(".hero");
    hero?.addEventListener("mouseenter", () => clearInterval(slideInterval));
    hero?.addEventListener("mouseleave", startAutoRotate);
</script>
