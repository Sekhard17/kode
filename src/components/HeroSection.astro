---
/**
 * Hero Section - Product Focused Design
 * Minimal text, products are the star
 */

interface Props {
    locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

const t = {
    es: {
        tagline: "Nueva Colección",
        cta: "Explorar",
    },
    en: {
        tagline: "New Collection",
        cta: "Explore",
    },
};

const text = t[locale];

const slides = [
    { image: "/hero/Kode1.png", alt: "KØDE Collection" },
    { image: "/hero/Kode2.png", alt: "KØDE Collection" },
    { image: "/hero/Kode3.png", alt: "KØDE Collection" },
];
---

<section class="hero">
    <!-- Background Carousel - Full visibility -->
    <div class="hero-carousel">
        {
            slides.map((slide, index) => (
                <div
                    class={`hero-slide ${index === 0 ? "active" : ""}`}
                    data-slide={index}
                >
                    <img
                        src={slide.image}
                        alt={slide.alt}
                        class="hero-image"
                        loading={index === 0 ? "eager" : "lazy"}
                    />
                </div>
            ))
        }
        <!-- Subtle gradient only at bottom for text -->
        <div class="hero-gradient"></div>
    </div>

    <!-- Minimal Content - Bottom Left -->
    <div class="hero-content">
        <div class="container-custom">
            <div class="hero-text">
                <span class="hero-tagline">{text.tagline}</span>
                <a href="/tienda" class="hero-cta">
                    {text.cta}
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>

    <!-- Indicators - Bottom Right -->
    <div class="hero-indicators">
        {
            slides.map((_, index) => (
                <button
                    class={`indicator ${index === 0 ? "active" : ""}`}
                    data-indicator={index}
                    aria-label={`Slide ${index + 1}`}
                >
                    <span class="indicator-progress" />
                </button>
            ))
        }
    </div>
</section>

<style>
    .hero {
        position: relative;
        width: 100%;
        height: 100svh;
        min-height: 500px;
        overflow: hidden;
        background: #000;
    }

    /* Carousel - Maximum visibility */
    .hero-carousel {
        position: absolute;
        inset: 0;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    .hero-slide.active {
        opacity: 1;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    @media (max-width: 768px) {
        .hero-image {
            object-position: center 25%;
        }
    }

    /* Minimal gradient - only bottom */
    .hero-gradient {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40%;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.6) 0%,
            rgba(0, 0, 0, 0) 100%
        );
        pointer-events: none;
    }

    /* Content - Bottom Left */
    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 10;
        padding-bottom: 3rem;
    }

    @media (min-width: 768px) {
        .hero-content {
            padding-bottom: 4rem;
        }
    }

    .hero-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }

    @media (max-width: 768px) {
        .hero-text {
            align-items: center;
            text-align: center;
            width: 100%;
        }
    }

    /* Tagline */
    .hero-tagline {
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.8);
        animation: fadeIn 0.8s ease forwards;
        animation-delay: 0.3s;
        opacity: 0;
    }

    /* CTA */
    .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 28px;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        color: #000;
        background: #fff;
        border: none;
        transition: all 0.3s ease;
        animation: fadeSlideUp 0.8s ease forwards;
        animation-delay: 0.5s;
        opacity: 0;
    }

    .hero-cta:hover {
        transform: translateX(4px);
        box-shadow: 0 10px 40px rgba(255, 255, 255, 0.15);
    }

    .hero-cta svg {
        width: 18px;
        height: 18px;
        transition: transform 0.3s ease;
    }

    .hero-cta:hover svg {
        transform: translateX(4px);
    }

    /* Indicators - Bottom Right */
    .hero-indicators {
        position: absolute;
        bottom: 3rem;
        right: 1.5rem;
        display: flex;
        gap: 8px;
        z-index: 20;
    }

    @media (min-width: 768px) {
        .hero-indicators {
            bottom: 4rem;
            right: 2rem;
        }
    }

    @media (max-width: 768px) {
        .hero-indicators {
            bottom: 3rem;
            left: 50%;
            right: auto;
            transform: translateX(-50%);
        }
    }

    .indicator {
        width: 32px;
        height: 3px;
        background: rgba(255, 255, 255, 0.3);
        border: none;
        border-radius: 2px;
        cursor: pointer;
        overflow: hidden;
        position: relative;
        transition: background 0.3s ease;
    }

    .indicator:hover {
        background: rgba(255, 255, 255, 0.5);
    }

    .indicator-progress {
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 0;
        background: #fff;
        border-radius: 2px;
    }

    .indicator.active .indicator-progress {
        animation: progress 5s linear forwards;
    }

    /* Animations */
    @keyframes fadeIn {
        to {
            opacity: 1;
        }
    }

    @keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes progress {
        from {
            width: 0;
        }
        to {
            width: 100%;
        }
    }
</style>

<script>
    const slides = document.querySelectorAll(".hero-slide");
    const indicators = document.querySelectorAll(".indicator");
    let currentSlide = 0;
    let slideInterval: ReturnType<typeof setInterval>;

    function goToSlide(index: number) {
        slides.forEach((slide) => slide.classList.remove("active"));
        indicators.forEach((ind) => ind.classList.remove("active"));
        slides[index]?.classList.add("active");
        indicators[index]?.classList.add("active");
        currentSlide = index;
    }

    function nextSlide() {
        goToSlide((currentSlide + 1) % slides.length);
    }

    function startAutoRotate() {
        slideInterval = setInterval(nextSlide, 5000);
    }

    indicators.forEach((indicator, index) => {
        indicator.addEventListener("click", () => {
            goToSlide(index);
            clearInterval(slideInterval);
            startAutoRotate();
        });
    });

    startAutoRotate();

    const hero = document.querySelector(".hero");
    hero?.addEventListener("mouseenter", () => clearInterval(slideInterval));
    hero?.addEventListener("mouseleave", startAutoRotate);
</script>
