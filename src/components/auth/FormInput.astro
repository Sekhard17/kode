---
/**
 * FormInput - Reusable input component with validation
 * Features: icon, label, error state, animations
 */

interface Props {
    type?: string;
    name: string;
    label: string;
    placeholder?: string;
    icon?: string;
    required?: boolean;
    autocomplete?: string;
    value?: string;
}

const {
    type = "text",
    name,
    label,
    placeholder = "",
    icon,
    required = false,
    autocomplete,
    value = "",
} = Astro.props;

// SVG icons mapping
const icons: Record<string, string> = {
    email: `<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>`,
    user: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>`,
    phone: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>`,
};
---

<div class="form-input-wrapper">
    <label for={name} class="form-label">
        {label}
        {required && <span class="required-indicator">*</span>}
    </label>
    <div class="input-container">
        {
            icon && icons[icon] && (
                <svg
                    class="input-icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    set:html={icons[icon]}
                />
            )
        }
        <input
            type={type}
            id={name}
            name={name}
            placeholder={placeholder}
            required={required}
            autocomplete={autocomplete}
            value={value}
            class:list={["form-input", { "has-icon": icon }]}
        />
    </div>
    <span class="error-message" data-error-for={name}></span>
</div>

<style>
    .form-input-wrapper {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-primary);
    }

    .required-indicator {
        color: var(--error);
        margin-left: 2px;
    }

    .input-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        width: 18px;
        height: 18px;
        color: var(--text-tertiary);
        pointer-events: none;
        transition: color 0.2s;
    }

    .form-input {
        width: 100%;
        padding: 0.875rem 1rem;
        font-size: 0.9375rem;
        color: var(--text-primary);
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        outline: none;
        transition: all 0.2s ease;
    }

    .form-input.has-icon {
        padding-left: 2.75rem;
    }

    .form-input::placeholder {
        color: var(--text-tertiary);
    }

    .form-input:hover {
        border-color: var(--border-hover);
    }

    .form-input:focus {
        border-color: var(--accent-primary);
        background: var(--bg-primary);
        box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.08);
    }

    :global(.dark) .form-input:focus {
        box-shadow: 0 0 0 3px rgba(250, 250, 250, 0.08);
    }

    .form-input:focus + .input-icon,
    .input-container:focus-within .input-icon {
        color: var(--accent-primary);
    }

    /* Error state */
    .form-input.error {
        border-color: var(--error);
        animation: shake 0.4s ease;
    }

    .form-input.error:focus {
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
    }

    .error-message {
        font-size: 0.8125rem;
        color: var(--error);
        min-height: 1.25rem;
        opacity: 0;
        transform: translateY(-4px);
        transition: all 0.2s ease;
    }

    .error-message.visible {
        opacity: 1;
        transform: translateY(0);
    }

    @keyframes shake {
        0%,
        100% {
            transform: translateX(0);
        }
        20%,
        60% {
            transform: translateX(-6px);
        }
        40%,
        80% {
            transform: translateX(6px);
        }
    }
</style>
