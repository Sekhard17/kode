---
/**
 * Product Card Component
 * Reusable card for displaying products
 */

import type { ProductListDto } from "../types";

interface Props {
    product: ProductListDto;
    locale?: "es" | "en";
}

const { product, locale = "es" } = Astro.props;

const t = {
    es: {
        addToCart: "Agregar",
        outOfStock: "Agotado",
        sale: "Oferta",
    },
    en: {
        addToCart: "Add to Cart",
        outOfStock: "Out of Stock",
        sale: "Sale",
    },
};

const text = t[locale];
---

<article class="product-card group" data-product-id={product.id}>
    <!-- Image container -->
    <a
        href={`/producto/${product.slug}`}
        class="block relative aspect-[3/4] overflow-hidden rounded-xl mb-4"
    >
        <!-- Badges -->
        <div class="absolute top-3 left-3 z-10 flex flex-col gap-2">
            {
                product.hasDiscount && (
                    <span class="badge badge-sale">
                        -{product.discountPercentage}%
                    </span>
                )
            }
        </div>

        <!-- Wishlist button -->
        <button
            class="wishlist-btn absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-white/80 dark:bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 hover:scale-110"
            aria-label="Agregar a favoritos"
            data-product-id={product.id}
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
            </svg>
        </button>

        <!-- Image -->
        {
            product.primaryImageUrl ? (
                <img
                    src={product.primaryImageUrl}
                    alt={product.name}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-full bg-[var(--bg-tertiary)] flex items-center justify-center">
                    <svg
                        class="w-16 h-16 text-tertiary"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1"
                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                        />
                    </svg>
                </div>
            )
        }

        <!-- Quick add overlay -->
        <div
            class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
            <button
                class="quick-add-btn w-full btn bg-white text-black hover:bg-gray-100 py-2 text-sm font-medium"
                data-product-id={product.id}
                disabled={!product.isAvailable}
            >
                {product.isAvailable ? text.addToCart : text.outOfStock}
            </button>
        </div>
    </a>

    <!-- Info -->
    <div class="space-y-2">
        <!-- Category -->
        <p class="text-xs text-tertiary uppercase tracking-wide">
            {product.categoryName}
        </p>

        <!-- Name -->
        <a href={`/producto/${product.slug}`}>
            <h3
                class="font-medium text-primary line-clamp-1 group-hover:text-[var(--accent-primary)] transition-colors"
            >
                {product.name}
            </h3>
        </a>

        <!-- Price -->
        <div class="flex items-center gap-2">
            <span
                class="product-price font-semibold"
                data-price={product.price}
            >
                <!-- Price will be formatted by JS based on currency -->
            </span>
            {
                product.compareAtPrice && (
                    <span
                        class="product-compare-price text-sm text-tertiary line-through"
                        data-price={product.compareAtPrice}
                    ></span>
                )
            }
        </div>
    </div>
</article>

<style>
    .product-card {
        transition: transform 0.3s ease;
    }

    .product-card:hover {
        transform: translateY(-4px);
    }
</style>

<script>
    import { formatPrice, getCurrency } from "../lib/currency";

    function updatePrices() {
        document.querySelectorAll(".product-price").forEach((el) => {
            const price = parseFloat((el as HTMLElement).dataset.price || "0");
            el.textContent = formatPrice(price);
        });

        document.querySelectorAll(".product-compare-price").forEach((el) => {
            const price = parseFloat((el as HTMLElement).dataset.price || "0");
            el.textContent = formatPrice(price);
        });
    }

    // Update on load
    document.addEventListener("DOMContentLoaded", updatePrices);

    // Update on currency change
    window.addEventListener("currency-changed", updatePrices);
</script>
