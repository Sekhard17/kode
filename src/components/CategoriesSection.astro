---
/**
 * Categories Section
 * Displays product categories from API
 */

import type { CategoryListDto } from '../types';

interface Props {
  locale?: 'es' | 'en';
}

const { locale = 'es' } = Astro.props;

const t = {
  es: {
    title: 'Categorías',
    viewAll: 'Ver Todo',
    products: 'productos',
  },
  en: {
    title: 'Categories',
    viewAll: 'View All',
    products: 'products',
  }
};

const text = t[locale];

// Fetch categories from API
let categories: CategoryListDto[] = [];

try {
  const res = await fetch('http://localhost:5133/api/categories');
  if (res.ok) {
    categories = await res.json();
  }
} catch (e) {
  console.error('Error fetching categories:', e);
}

// Placeholder images for categories
const categoryImages: Record<string, string> = {
  'hoodies': 'https://images.unsplash.com/photo-1556821840-3a63f95609a7?w=400&h=500&fit=crop',
  'poleras': 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400&h=500&fit=crop',
  't-shirts': 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400&h=500&fit=crop',
  'pantalones': 'https://images.unsplash.com/photo-1542272604-787c3835535d?w=400&h=500&fit=crop',
  'pants': 'https://images.unsplash.com/photo-1542272604-787c3835535d?w=400&h=500&fit=crop',
  'accesorios': 'https://images.unsplash.com/photo-1523293182086-7651a899d37f?w=400&h=500&fit=crop',
  'accessories': 'https://images.unsplash.com/photo-1523293182086-7651a899d37f?w=400&h=500&fit=crop',
};
---

<section class="section bg-secondary">
  <div class="container-custom">
    <!-- Header -->
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-3xl md:text-4xl font-bold">{text.title}</h2>
      <a href="/categorias" class="btn btn-secondary text-sm">
        {text.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
    
    <!-- Categories Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {categories.map((category) => (
        <a 
          href={`/categoria/${category.slug}`} 
          class="category-card group relative aspect-[3/4] rounded-2xl overflow-hidden"
        >
          <!-- Image -->
          <img 
            src={category.imageUrl || categoryImages[category.slug.toLowerCase()] || 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=400&h=500&fit=crop'} 
            alt={category.name}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          
          <!-- Content -->
          <div class="absolute inset-x-0 bottom-0 p-6">
            <h3 class="text-xl font-semibold text-white mb-1">{category.name}</h3>
            <p class="text-sm text-white/70">{category.productCount} {text.products}</p>
          </div>
          
          <!-- Hover arrow -->
          <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .category-card {
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
  }
  
  .category-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }
</style>
