---
/**
 * Categories Section - Minimal Luxury Design
 * Clean, elegant cards with subtle hover effects
 */

import type { CategoryListDto } from "../types";

interface Props {
  locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;

const t = {
  es: {
    title: "Categorías",
    viewAll: "Explorar",
    products: "productos",
  },
  en: {
    title: "Categories",
    viewAll: "Explore",
    products: "products",
  },
};

const text = t[locale];

// Fetch categories from API
let categories: CategoryListDto[] = [];

try {
  const res = await fetch("http://localhost:5133/api/categories");
  if (res.ok) {
    categories = await res.json();
  }
} catch (e) {
  console.error("Error fetching categories:", e);
}

// Elegant placeholder images
const categoryImages: Record<string, string> = {
  hoodies:
    "https://images.unsplash.com/photo-1556821840-3a63f95609a7?w=600&h=800&fit=crop&q=80",
  poleras:
    "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop&q=80",
  "t-shirts":
    "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop&q=80",
  pantalones:
    "https://images.unsplash.com/photo-1542272604-787c3835535d?w=600&h=800&fit=crop&q=80",
  pants:
    "https://images.unsplash.com/photo-1542272604-787c3835535d?w=600&h=800&fit=crop&q=80",
  accesorios:
    "https://images.unsplash.com/photo-1523293182086-7651a899d37f?w=600&h=800&fit=crop&q=80",
  accessories:
    "https://images.unsplash.com/photo-1523293182086-7651a899d37f?w=600&h=800&fit=crop&q=80",
};

const defaultImage =
  "https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&h=800&fit=crop&q=80";
---

<section class="categories" id="categories">
  <div class="categories__container">
    <!-- Header -->
    <header class="categories__header">
      <h2 class="categories__title">{text.title}</h2>
    </header>

    <!-- Grid -->
    {
      categories.length > 0 && (
        <div class="categories__grid">
          {categories.map((category, index) => (
            <a
              href={`/categoria/${category.slug}`}
              class="category"
              style={`--delay: ${index * 0.1}s`}
            >
              <div class="category__image-wrapper">
                <img
                  src={
                    category.imageUrl ||
                    categoryImages[category.slug.toLowerCase()] ||
                    defaultImage
                  }
                  alt={category.name}
                  class="category__image"
                  loading="lazy"
                />
                <div class="category__overlay" />
              </div>

              <div class="category__content">
                <h3 class="category__name">{category.name}</h3>
                <span class="category__arrow">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      d="M7 17L17 7M17 7H7M17 7V17"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .categories {
    padding: 6rem 0;
    background: var(--bg-secondary);
  }

  .categories__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .categories__header {
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .categories__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  /* Grid - Asymmetric layout */
  .categories__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .categories__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, 280px);
      gap: 1.5rem;
    }

    /* First category spans 2 columns and 2 rows */
    .categories__grid .category:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  /* Category Card */
  .category {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    animation: fadeIn 0.6s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .category__image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 280px;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .category__image-wrapper {
      min-height: 100%;
    }
  }

  .category__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .category:hover .category__image {
    transform: scale(1.08);
  }

  .category__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      rgba(0, 0, 0, 0) 100%
    );
    transition: opacity 0.4s ease;
  }

  .category:hover .category__overlay {
    opacity: 0.8;
  }

  /* Content */
  .category__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    padding: 1.5rem;
    color: white;
  }

  @media (min-width: 1024px) {
    .category__content {
      padding: 2rem;
    }
  }

  .category__name {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    transform: translateY(0);
    transition: transform 0.4s ease;
  }

  @media (min-width: 1024px) {
    .categories__grid .category:first-child .category__name {
      font-size: 2rem;
    }
  }

  .category:hover .category__name {
    transform: translateY(-4px);
  }

  .category__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.4s ease;
  }

  .category:hover .category__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .category__arrow:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Mobile optimizations */
  @media (hover: none) {
    .category__arrow {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
