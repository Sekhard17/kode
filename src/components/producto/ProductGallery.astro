---
/**
 * ProductGallery - Galería de imágenes premium con zoom y thumbnails
 */

import type { ProductImageDto } from "../../types";

interface Props {
    images: ProductImageDto[];
    productName: string;
}

const { images, productName } = Astro.props;

// Ordenar imágenes: primaria primero, luego por displayOrder
const sortedImages = [...images].sort((a, b) => {
    if (a.isPrimary) return -1;
    if (b.isPrimary) return 1;
    return a.displayOrder - b.displayOrder;
});

const primaryImage = sortedImages[0] || null;
const hasMultipleImages = sortedImages.length > 1;
---

<div class="product-gallery">
    <!-- Imagen Principal -->
    <div class="main-image-container">
        {primaryImage ? (
            <div class="main-image-wrapper" data-zoom-container>
                <img
                    id="main-product-image"
                    src={primaryImage.url}
                    alt={primaryImage.altText || productName}
                    class="main-image"
                    loading="eager"
                />
                <!-- Zoom overlay -->
                <div class="zoom-lens" data-zoom-lens></div>
            </div>
        ) : (
            <div class="no-image">
                <svg class="w-24 h-24 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span class="text-tertiary text-sm mt-2">Sin imagen</span>
            </div>
        )}
    </div>

    <!-- Thumbnails -->
    {hasMultipleImages && (
        <div class="thumbnails-container">
            <div class="thumbnails-scroll">
                {sortedImages.map((img, index) => (
                    <button
                        class={`thumbnail ${index === 0 ? 'active' : ''}`}
                        data-image-url={img.url}
                        data-image-alt={img.altText || productName}
                        aria-label={`Ver imagen ${index + 1}`}
                    >
                        <img
                            src={img.url}
                            alt={img.altText || `${productName} - ${index + 1}`}
                            loading="lazy"
                        />
                    </button>
                ))}
            </div>
        </div>
    )}
</div>

<style>
    .product-gallery {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        position: sticky;
        top: 6rem;
    }

    @media (max-width: 1023px) {
        .product-gallery {
            position: static;
        }
    }

    .main-image-container {
        position: relative;
        aspect-ratio: 1;
        border-radius: 1.5rem;
        overflow: hidden;
        background-color: var(--bg-secondary);
    }

    .main-image-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
        cursor: zoom-in;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .main-image-wrapper:hover .main-image {
        transform: scale(1.1);
    }

    .zoom-lens {
        position: absolute;
        width: 150px;
        height: 150px;
        border: 2px solid var(--accent-primary);
        border-radius: 50%;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.2s ease;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(2px);
    }

    .main-image-wrapper:hover .zoom-lens {
        opacity: 1;
    }

    .no-image {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        background-color: var(--bg-tertiary);
    }

    /* Thumbnails */
    .thumbnails-container {
        width: 100%;
        overflow: hidden;
    }

    .thumbnails-scroll {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        padding: 0.25rem;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .thumbnails-scroll::-webkit-scrollbar {
        display: none;
    }

    .thumbnail {
        flex-shrink: 0;
        width: 5rem;
        height: 5rem;
        border-radius: 0.75rem;
        overflow: hidden;
        border: 2px solid transparent;
        transition: all 0.3s ease;
        cursor: pointer;
        background: var(--bg-secondary);
    }

    .thumbnail:hover {
        border-color: var(--border-hover);
    }

    .thumbnail.active {
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.1);
    }

    :global(.dark) .thumbnail.active {
        box-shadow: 0 0 0 3px rgba(250, 250, 250, 0.1);
    }

    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .thumbnail:hover img {
        transform: scale(1.1);
    }
</style>

<script>
    function initGallery() {
        const mainImage = document.getElementById('main-product-image') as HTMLImageElement | null;
        const thumbnails = document.querySelectorAll<HTMLButtonElement>('.thumbnail');
        const zoomContainer = document.querySelector<HTMLDivElement>('[data-zoom-container]');
        const zoomLens = document.querySelector<HTMLDivElement>('[data-zoom-lens]');

        if (!mainImage) return;

        // Thumbnail click handler
        thumbnails.forEach(thumb => {
            thumb.addEventListener('click', () => {
                const newUrl = thumb.dataset.imageUrl;
                const newAlt = thumb.dataset.imageAlt;

                if (newUrl && mainImage) {
                    mainImage.style.opacity = '0';
                    setTimeout(() => {
                        mainImage.src = newUrl;
                        mainImage.alt = newAlt || '';
                        mainImage.style.opacity = '1';
                    }, 150);

                    thumbnails.forEach(t => t.classList.remove('active'));
                    thumb.classList.add('active');
                }
            });
        });

        // Zoom lens follow cursor
        if (zoomContainer && zoomLens) {
            zoomContainer.addEventListener('mousemove', (e) => {
                const rect = zoomContainer.getBoundingClientRect();
                const x = e.clientX - rect.left - zoomLens.offsetWidth / 2;
                const y = e.clientY - rect.top - zoomLens.offsetHeight / 2;

                zoomLens.style.left = `${x}px`;
                zoomLens.style.top = `${y}px`;
            });
        }
    }

    document.addEventListener('DOMContentLoaded', initGallery);
    document.addEventListener('astro:page-load', initGallery);
</script>
