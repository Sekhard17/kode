---
/**
 * =================================================================
 * CARRITO DE COMPRAS - KØDE Streetwear
 * =================================================================
 *
 * ARQUITECTURA CLEAN:
 * - Los tipos vienen de /types
 * - La lógica del carrito está en /lib/cart-store.ts
 * - Las traducciones están en /lib/translations/cart.ts
 * - Los componentes de UI están en /components/carrito-compras/
 * - Este archivo solo maneja las importaciones y configuración
 */

// ============ IMPORTS ============

// Layout y componentes globales
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

// Componentes del carrito
import CartItemList from "../components/carrito-compras/CartItemList.astro";
import OrderSummary from "../components/carrito-compras/OrderSummary.astro";
import ContinueShopping from "../components/carrito-compras/ContinueShopping.astro";
import CartClientScript from "../components/carrito-compras/CartClientScript.astro";

// Utilidades y traducciones
import { getCartTranslations } from "../lib/translations/cart";
import {
    createDemoCart,
    hasFreeShipping,
    getFreeShippingProgress,
} from "../lib/cart-store";

// ============ CONFIGURACIÓN ============

// Obtener idioma de la cookie
const locale = (Astro.cookies.get("kode_locale")?.value as "es" | "en") || "es";
const text = getCartTranslations(locale);

// Obtener datos del carrito
const cart = createDemoCart();
const { items, subtotal } = cart;

// Calcular información de envío
const isFreeShipping = hasFreeShipping(subtotal);
const shippingProgress = getFreeShippingProgress(subtotal);
---

<Layout
    title={`${text.title} | KØDE`}
    description="Tu carrito de compras en KØDE - Streetwear Premium"
>
    <Navbar locale={locale} />

    <main class="pt-[104px] min-h-screen bg-primary">
        <div class="container-custom py-8 md:py-12">
            <!-- Título -->
            <h1 class="text-3xl md:text-4xl font-bold mb-8 animate-fade-in">
                {text.title}
            </h1>

            <!-- Grid principal -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Lista de productos -->
                <CartItemList items={items} text={text} />

                <!-- Resumen del pedido -->
                <OrderSummary
                    subtotal={subtotal}
                    isFreeShipping={isFreeShipping}
                    shippingProgress={shippingProgress}
                    text={text}
                />
            </div>

            <!-- Enlace continuar comprando -->
            <ContinueShopping text={text} />
        </div>
    </main>

    <Footer locale={locale} />
</Layout>

<!-- Script de cliente -->
<CartClientScript />

<style>
    .bg-primary {
        background-color: var(--bg-primary);
    }
</style>
